[
  {"id":1,"test":1,"testName":"Fiber Optics","chapter":"Fiber Optics","q":"Minimum modal bandwidth of OM3 fiber at 850 nm?","o":["1500 MHz·km","2000 MHz·km","500 MHz·km","3500 MHz·km"],"a":1,"w":"OM3 minimum modal bandwidth is 2000 MHz·km at 850 nm. 3500 MHz·km is OM4. 500 MHz·km is the 1300 nm value for OM3."},
  {"id":2,"test":1,"testName":"Fiber Optics","chapter":"Fiber Optics","q":"OS2 single-mode fiber maximum attenuation at 1550 nm is:","o":["1.0 dB/km","0.4 dB/km","1.5 dB/km","0.2 dB/km"],"a":1,"w":"OS2 max attenuation is 0.4 dB/km at both 1310 nm and 1550 nm per BICSI TDMM."},
  {"id":3,"test":1,"testName":"Fiber Optics","chapter":"Fiber Optics","q":"Which fiber type has the widest core diameter?","o":["8.3 µm SMF","50 µm OM3","62.5 µm OM1","9 µm OS2"],"a":2,"w":"62.5 µm multimode (OM1/OM2) has the widest core. SMF is 8–9 µm. OM3/OM4 are 50 µm. Wider core means more modal paths and more modal dispersion."},
  {"id":4,"test":1,"testName":"Fiber Optics","chapter":"Fiber Optics","q":"OTDR launch and receive cords must each be longer than:","o":["The fiber under test","The OTDR dead zone","50 m","The splice spacing"],"a":1,"w":"Each cord must exceed the OTDR dead zone length. Without them, the first and last connectors are invisible to the OTDR — it is saturated in that region."},
  {"id":5,"test":1,"testName":"Fiber Optics","chapter":"Fiber Optics","q":"OM4 multimode fiber minimum OFL bandwidth at 850 nm is:","o":["2000 MHz·km","3500 MHz·km","4700 MHz·km","1500 MHz·km"],"a":2,"w":"OM4 minimum OFL bandwidth is 4700 MHz·km at 850 nm. OM3 is 2000 MHz·km. This higher bandwidth enables longer 40G/100G reaches than OM3."},
  {"id":6,"test":2,"testName":"Copper Cabling","chapter":"Copper Cabling","q":"Category 6A / Class EA cabling supports frequencies up to:","o":["250 MHz","350 MHz","500 MHz","1000 MHz"],"a":2,"w":"Cat 6A / Class EA is specified to 500 MHz. Cat 5e = 100 MHz. Cat 6 = 250 MHz. Cat 7A = 1000 MHz. 500 MHz enables 10GBASE-T."},
  {"id":7,"test":2,"testName":"Copper Cabling","chapter":"Copper Cabling","q":"Maximum permanent link length for horizontal copper cabling is:","o":["100 m","90 m","80 m","70 m"],"a":1,"w":"Permanent link limit = 90 m (295 ft). Full channel including patch cords = 100 m. The extra 10 m accounts for equipment cords at each end."},
  {"id":8,"test":2,"testName":"Copper Cabling","chapter":"Copper Cabling","q":"PSAACRF formula uses which attenuation value?","o":["Minimum attenuation","Maximum attenuation","Average attenuation","RMS attenuation"],"a":1,"w":"PSAACRF uses MAXIMUM attenuation. Some study notes incorrectly state minimum — the correct TDMM formula uses maximum attenuation, representing worst-case signal level scenario."},
  {"id":9,"test":2,"testName":"Copper Cabling","chapter":"Copper Cabling","q":"PoE Type 4 (IEEE 802.3bt) maximum power at source is:","o":["30 W","60 W","90 W","100 W"],"a":2,"w":"Type 1=15.4W, Type 2=30W, Type 3=60W, Type 4=90W. Type 4 uses all 4 pairs and delivers up to 71.3W to the powered device after cable loss."},
  {"id":10,"test":2,"testName":"Copper Cabling","chapter":"Copper Cabling","q":"PoE Type 1 (802.3af) maximum current per conductor is:","o":["600 mA","400 mA","175 mA","300 mA"],"a":2,"w":"PoE Type 1 limits current to 175 mA per conductor. This value is critical for cable bundle heating analysis. Higher Type ratings have higher currents requiring bundle derating."},
  {"id":11,"test":3,"testName":"Telecom Spaces","chapter":"Telecom Spaces","q":"Minimum working clearance in front AND rear of equipment in a TR is:","o":["0.5 m (1.6 ft)","1.5 m (4.9 ft)","1.0 m (3.28 ft)","0.75 m (2.5 ft)"],"a":2,"w":"BICSI TDMM requires at least 1 m (3.28 ft) of working clearance both in front of and behind installed equipment in TRs, ERs, and data center spaces."},
  {"id":12,"test":3,"testName":"Telecom Spaces","chapter":"Telecom Spaces","q":"HVAC sensors in equipment rooms should be placed at height AFF of:","o":["1.0 m (3.28 ft)","2.0 m (6.56 ft)","1.52 m (5 ft)","0.9 m (3 ft)"],"a":2,"w":"1.52 m (5 ft) AFF is the thermal mid-point of standard 2.1 m racks and gives the most accurate environmental reading for the equipment heat zone."},
  {"id":13,"test":3,"testName":"Telecom Spaces","chapter":"Telecom Spaces","q":"Minimum ceiling height for a Telecommunications Room (TR) is:","o":["2.0 m (6.5 ft)","3.0 m (10 ft)","2.4 m (8 ft)","1.8 m (6 ft)"],"a":2,"w":"Minimum TR ceiling height = 2.4 m (8 ft) AFF. This accommodates 2.1 m racks plus cable management overhead. For ERs, 3 m (10 ft) is recommended."},
  {"id":14,"test":3,"testName":"Telecom Spaces","chapter":"Telecom Spaces","q":"Recommended termination space for each 4-pair horizontal circuit is:","o":["645 mm² (1 in²)","1290 mm² (2 in²)","2580 mm² (4 in²)","3870 mm² (6 in²)"],"a":2,"w":"2580 mm² (4 in²) per 4-pair circuit at hardware. For optical fiber, 1290 mm² (2 in²) per strand. Fiber uses half the hardware footprint of copper — exam-critical distinction."},
  {"id":15,"test":3,"testName":"Telecom Spaces","chapter":"Telecom Spaces","q":"Minimum clearance below fire sprinkler heads is:","o":["305 mm (12 in)","610 mm (24 in)","457 mm (18 in)","152 mm (6 in)"],"a":2,"w":"At least 457 mm (18 in) clearance below sprinkler heads is mandatory to ensure effective water dispersal. Obstructions within 18 in deflect spray and reduce fire suppression effectiveness."},
  {"id":16,"test":4,"testName":"Grounding & Power","chapter":"Grounding","q":"Maximum length of the Telecommunications Bonding Conductor (TBC) is:","o":["5 m","15 m","9 m","30 m"],"a":2,"w":"TBC max = 9 m (30 ft). Longer runs increase impedance, defeating the bonding purpose. TBC should measure 0 A during normal operation — current above 1 A indicates a fault."},
  {"id":17,"test":4,"testName":"Grounding & Power","chapter":"Grounding","q":"Recommended bonding resistance between electrode and telecom busbar is:","o":["0.5 ohm","1.0 ohm","0.1 ohm","0.01 ohm"],"a":2,"w":"0.1 ohm is the target. Higher resistance creates potential differences causing ground loops, EMI, and equipment damage. Must use a low-resistance milliohm meter to verify."},
  {"id":18,"test":4,"testName":"Grounding & Power","chapter":"Grounding","q":"Standard dimensions of the TGB (Telecom Grounding Busbar) are:","o":["3 mm x 25 mm","6 mm x 50 mm","9 mm x 75 mm","12 mm x 100 mm"],"a":1,"w":"TGB standard = 6 mm thick x 50 mm wide, variable length. The TMGB/PBB (Primary Busbar) is larger. TGB = SBB (Secondary Bonding Busbar) in international terminology."},
  {"id":19,"test":4,"testName":"Grounding & Power","chapter":"Grounding","q":"A 'sag' in power quality lasts:","o":["Total absence of voltage","0.5 cycle to 1 minute","Voltage decrease more than 1 minute","Sub-cycle transient only"],"a":1,"w":"Sag = voltage decrease, 0.5 cycle to 1 minute. Undervoltage = decrease more than 1 min. Interruption = complete absence. Transient = sub-cycle event. These definitions drive UPS specifications."},
  {"id":20,"test":4,"testName":"Grounding & Power","chapter":"Power","q":"How many watts of heat load require 1 ton of air conditioning?","o":["1200 W","2500 W","3517 W","5000 W"],"a":2,"w":"3517 W = 12,000 BTU/hr = 1 ton of cooling. Divide total IT heat load in watts by 3517 to get required cooling in tons. Essential for data center cooling calculations."},
  {"id":21,"test":5,"testName":"Wireless & RF","chapter":"Wireless","q":"Wi-Fi 6 (IEEE 802.11ax) throughput improvement over Wi-Fi 5 per BICSI notes is:","o":["100%","200%","400%","800%"],"a":2,"w":"400% improvement via OFDMA, BSS Coloring, and improved MU-MIMO. This is the BICSI study notes value — the gain comes from improved spectral efficiency in dense deployments."},
  {"id":22,"test":5,"testName":"Wireless & RF","chapter":"Wireless","q":"Reliable RF Line-of-Sight requires what Fresnel Zone clearance?","o":["80%","40%","60%","100%"],"a":2,"w":"60% Fresnel Zone clearance is needed for reliable LoS RF propagation. Below 60%, diffraction losses become significant. The Fresnel Zone is an ellipsoidal region around the direct TX-RX path."},
  {"id":23,"test":5,"testName":"Wireless & RF","chapter":"Wireless","q":"IEEE 802.11b achieves 11 Mbps using which modulation?","o":["BPSK","QPSK","CCK","QAM-16"],"a":2,"w":"802.11b uses CCK (Complementary Code Keying) at 5.5 and 11 Mbps. At 1 and 2 Mbps it uses DBPSK and DQPSK. CCK enabled higher rates than original 802.11 without changing the spread-spectrum approach."},
  {"id":24,"test":5,"testName":"Wireless & RF","chapter":"Wireless","q":"EIRP (Effective Isotropic Radiated Power) is calculated as:","o":["Tx power + cable loss","Tx power minus cable loss plus antenna gain","Tx power times antenna gain","Antenna gain divided by cable loss"],"a":1,"w":"EIRP (dBm) = Transmit Power (dBm) minus Cable Loss (dB) plus Antenna Gain (dBi). EIRP is regulated by FCC. Exceeding EIRP limits is an FCC Part 15 violation."},
  {"id":25,"test":5,"testName":"Wireless & RF","chapter":"Wireless","q":"Wireless Medical Telemetry Services (WMTS) operate at:","o":["433-434 MHz","608-614 MHz","900-928 MHz","2.4 GHz"],"a":1,"w":"WMTS uses the dedicated protected band 608-614 MHz in the US. No individual license required. Protected spectrum prevents interference from other wireless devices — critical for patient vital monitoring."},
  {"id":26,"test":6,"testName":"OSP & Backbone","chapter":"OSP","q":"Minimum burial depth for underground telecom conduit top is:","o":["12 in (305 mm)","18 in (457 mm)","24 in (610 mm)","36 in (914 mm)"],"a":2,"w":"Top of underground conduit must be at least 610 mm (24 in) below grade. Orange warning tape is buried at least 12 in above the cable to alert future excavators."},
  {"id":27,"test":6,"testName":"OSP & Backbone","chapter":"OSP","q":"Trench depth per BICSI specification is:","o":["3 ft (91 cm)","4 ft (122 cm)","5 ft (152 cm)","6 ft (183 cm)"],"a":2,"w":"Trenches must be 5 ft (152 cm) deep per BICSI. Deeper than 5 ft requires stepped trenches. Each step must not exceed 4 ft (122 cm). A 2 ft setback from excavated dirt prevents cave-ins."},
  {"id":28,"test":6,"testName":"OSP & Backbone","chapter":"OSP","q":"Maximum aerial span from last pole to building entrance is:","o":["15 m (50 ft)","20 m (65 ft)","30.5 m (100 ft)","50 m (164 ft)"],"a":2,"w":"Aerial span from last utility pole to building entry must not exceed 30.5 m (100 ft). Beyond this, additional pole support is required. Limit accounts for sag, ice loading, and wind stress."},
  {"id":29,"test":6,"testName":"OSP & Backbone","chapter":"OSP","q":"Separation between telecom and gas pipes at crossings must be:","o":["77 mm (3 in) concrete","305 mm (12 in)","152 mm (6 in)","600 mm (24 in)"],"a":2,"w":"152 mm (6 in) separation at crossings with gas pipes. 305 mm (12 in) for parallel runs alongside water pipes. 77 mm (3 in) poured concrete separates telecom from power conduit."},
  {"id":30,"test":6,"testName":"OSP & Backbone","chapter":"Network Design","q":"Class 4 data center key feature is:","o":["Single point of failure allowed","No redundancy required","No single point of failure — 2N+N fault-tolerant","One entrance room only"],"a":2,"w":"Class 4 = fault-tolerant, 2(N+N) configuration, no single point of failure, automatic failover. Class 3 = concurrently maintainable. Class 4 requires 2 HDAs per EDA."},
  {"id":31,"test":7,"testName":"EMC & Fire Protection","chapter":"EMC","q":"Radiated interference is measured over which frequency range?","o":["100 kHz to 30 MHz","30 MHz to 1 GHz","30 MHz to 5 GHz","1 MHz to 1 GHz"],"a":2,"w":"Radiated EMI: 30 MHz to 5 GHz. Conducted EMI: 100 kHz to 30 MHz. The 30 MHz boundary marks where EMI transitions from conducted to radiated coupling as the dominant mechanism."},
  {"id":32,"test":7,"testName":"EMC & Fire Protection","chapter":"EMC","q":"Minimum CMRR (Common Mode Rejection Ratio) for balanced pairs is:","o":["20 dB","40 dB","60 dB","80 dB"],"a":1,"w":"Minimum desirable CMRR = 40 dB. Measures how well the cable rejects common-mode noise. 40 dB = 100:1 noise rejection ratio. Below 40 dB provides poor noise immunity."},
  {"id":33,"test":7,"testName":"EMC & Fire Protection","chapter":"Fire Protection","q":"Which firestopping material is ideal for large openings?","o":["Silicone foam","Caulk or sealant","Cementitious material","Intumescent putty"],"a":2,"w":"Cementitious firestop material is ideal for large openings due to bulk fill capability. Caulk suits small openings. Pillows suit frequent-change areas. Intumescent wrap is for cables that may burn away."},
  {"id":34,"test":7,"testName":"EMC & Fire Protection","chapter":"Fire Protection","q":"ASTM E814 / UL 1479 evaluates which type of firestop system?","o":["Floor and wall assemblies","Expansion joint firestops","Through-penetration firestop systems","Electrical panel separations"],"a":2,"w":"ASTM E814 / UL 1479 = through-penetration firestop systems (cables, conduit, pipes penetrating rated assemblies). ASTM E1966 / UL 2079 = joints. ASTM E119 / UL 263 = wall/floor assemblies."},
  {"id":35,"test":7,"testName":"EMC & Fire Protection","chapter":"Fire Protection","q":"The F rating in US firestopping measures:","o":["Temperature rise on unexposed side","Time the firestop prevents flame passage","Smoke transmission rate","Water resistance rating"],"a":1,"w":"F rating = time the firestop system resists flame passage. T rating = time to temperature rise on unexposed side. W rating = water leakage resistance for 72 hours. L rating = air leakage."},
  {"id":36,"test":8,"testName":"Project Management","chapter":"Project Mgmt","q":"In Design-Build (DB), who oversees both design and construction?","o":["Owner's representative","Design professional only","The contractor","Construction Manager"],"a":2,"w":"In DB the contractor controls both design and construction. In DBB the design professional works for the owner and construction is bid separately. CMAR acts as consultant then transitions to GC."},
  {"id":37,"test":8,"testName":"Project Management","chapter":"Project Mgmt","q":"MasterFormat Division 27 covers:","o":["Electronic Safety and Security","Electrical","Plumbing","Communications"],"a":3,"w":"Division 27 = Communications (ICT cabling, AV, voice). Division 28 = Electronic Safety and Security. Division 26 = Electrical. Division 22 = Plumbing."},
  {"id":38,"test":8,"testName":"Project Management","chapter":"Project Mgmt","q":"PERT estimation weighted average formula is:","o":["(O + M + P) divided by 3","(O + 4M + P) divided by 6","(O + 2M + P) divided by 4","(O + 3M + P) divided by 5"],"a":1,"w":"PERT: (Optimistic + 4 x Most Likely + Pessimistic) divided by 6. The 4x weighting on Most Likely reflects that it is the most probable outcome. PERT also defines critical path and float."},
  {"id":39,"test":8,"testName":"Project Management","chapter":"Project Mgmt","q":"The Critical Path in project scheduling is:","o":["The longest path with zero float","The shortest possible project duration","The path with the most activities","The most expensive sequence of work"],"a":0,"w":"Critical Path = the longest sequence of dependent activities from start to finish with zero float. Any delay on the critical path directly delays project completion. Off-critical activities have positive float."},
  {"id":40,"test":8,"testName":"Project Management","chapter":"Project Mgmt","q":"A Change Order (CO) in a construction contract requires:","o":["Contractor approval only","Owner approval only","Owner, contractor, and design professional approval","Design professional approval only"],"a":2,"w":"A Change Order is a formal tri-party agreement signed by owner, contractor, and design professional. It modifies contract scope, price, and/or schedule. Without all three signatures it is not a valid CO."},
  {"id":41,"test":9,"testName":"Data Centers & Special","chapter":"Data Centers","q":"Data center availability Class F4 achieves which uptime?","o":["99.9%","99.99%","99.999%","100%"],"a":2,"w":"Class F4 = 99.999% availability (approximately 5 minutes per year downtime) with fully automated systems. F3 = 99.99%, F2 = 99.9%, F1 = 99.0%. F4 requires fully redundant automated systems."},
  {"id":42,"test":9,"testName":"Data Centers & Special","chapter":"Data Centers","q":"Overhead cable trays in data centers must be at least this high above finished floor:","o":["2.0 m (6.5 ft)","2.5 m (8.2 ft)","2.75 m (9 ft)","3.0 m (9.8 ft)"],"a":2,"w":"2.75 m (9 ft) minimum above finished floor for overhead cable trays in data centers. This allows personnel to stand beneath them safely and accommodates equipment removal from 2.1 m racks."},
  {"id":43,"test":9,"testName":"Data Centers & Special","chapter":"Data Centers","q":"Planned pathway fill capacity in data centers should not exceed:","o":["25%","40%","60%","50%"],"a":1,"w":"Planned capacity = 40% by cross-sectional area, maximum fill = 50%. The 40% limit leaves room for future growth and thermal dissipation. Installing to 100% fill makes any future cable addition extremely difficult."},
  {"id":44,"test":9,"testName":"Data Centers & Special","chapter":"Special Design","q":"MICE 3 classification describes which environment?","o":["Commercial","Light industrial","Harsh industrial","Residential"],"a":2,"w":"MICE 3 = harsh industrial (most severe). MICE 2 = light industrial. MICE 1 = commercial environments. Per TIA-1005 and ISO/IEC 11801-3. Machine areas within industrial premises are classified as MICE 3."},
  {"id":45,"test":9,"testName":"Data Centers & Special","chapter":"Special Design","q":"IP code digit y=7 denotes protection against:","o":["Splashing water","High-pressure jets","Temporary immersion up to 1 m for 30 min","Prolonged submersion beyond 1 m"],"a":2,"w":"y=4 = splashing, y=5 = low-pressure jets, y=6 = high-pressure jets, y=7 = temporary immersion up to 1 m for 30 min, y=8 = continuous submersion beyond 1 m."},
  {"id":46,"test":10,"testName":"AV, BAS & Administration","chapter":"AV Systems","q":"HDBaseT transports AV signals over balanced twisted-pair up to:","o":["50 m (164 ft)","75 m (246 ft)","100 m (328 ft)","150 m (492 ft)"],"a":2,"w":"HDBaseT transports 4K UHD video, audio, RS-232, IR, and Power over HDBaseT (up to 100 W) up to 100 m over Cat 5e or higher. Compare: HDMI passive is approximately 9 m, HD-SDI is 100 m at 1.485 Gb/s."},
  {"id":47,"test":10,"testName":"AV, BAS & Administration","chapter":"AV Systems","q":"Noise Criteria (NC) value for sound masking should not exceed:","o":["NC 25","NC 30","NC 35","NC 45"],"a":2,"w":"NC 35 is the maximum for sound masking. Above NC 35 the masking noise itself becomes intrusive. Below NC 25 the environment is too quiet for masking to provide speech privacy."},
  {"id":48,"test":10,"testName":"AV, BAS & Administration","chapter":"BAS","q":"BAS coverage area per device in commercial office buildings is approximately:","o":["10 m² (108 ft²)","15 m² (161 ft²)","23 m² (248 ft²)","30 m² (323 ft²)"],"a":2,"w":"One BAS device covers approximately 23 m² (248 ft²) of commercial office or hotel space. This value drives HCP placement density and ER sizing calculations."},
  {"id":49,"test":10,"testName":"AV, BAS & Administration","chapter":"Administration","q":"Color code for horizontal cabling in cross-connect fields per TIA-606 is:","o":["White","Orange","Purple","Blue"],"a":3,"w":"Blue = horizontal cabling. White = first-level backbone. Gray = second-level backbone. Purple = common equipment. Orange = demarcation point. Brown = campus backbone."},
  {"id":50,"test":10,"testName":"AV, BAS & Administration","chapter":"Administration","q":"For Class 2 administration, which records are MANDATORY per TIA-606?","o":["Pathway records","Firestop location records","Equipment records","Room floor plans"],"a":1,"w":"In Class 2, firestop location records are MANDATORY. Pathway administration is optional. Equipment records and floor plans are optional. Mandatory vs optional record types by class is frequently tested."}
